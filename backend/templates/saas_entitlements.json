{
  "name": "SaaS Entitlements",
  "description": "Feature gating via plan subscriptions with conditional limits (user → org → plan → feature).",
  "tags": ["saas", "entitlements", "conditions", "billing"],
  "model": {
    "schema_version": "1.1",
    "types": [
      { "name": "user", "relations": [] },
      {
        "name": "organization",
        "relations": [
          {
            "name": "member",
            "expression": {
              "kind": "direct",
              "grants": [
                { "type": "user", "relation": null, "wildcard": false, "condition": null }
              ]
            },
            "comment": null
          }
        ]
      },
      {
        "name": "plan",
        "relations": [
          {
            "name": "subscriber",
            "expression": {
              "kind": "direct",
              "grants": [
                { "type": "organization", "relation": "member", "wildcard": false, "condition": null }
              ]
            },
            "comment": null
          }
        ]
      },
      {
        "name": "feature",
        "relations": [
          {
            "name": "has_feature",
            "expression": {
              "kind": "direct",
              "grants": [
                { "type": "plan", "relation": "subscriber", "wildcard": false, "condition": null },
                { "type": "plan", "relation": "subscriber", "wildcard": false, "condition": "is_below_collaborator_limit" },
                { "type": "plan", "relation": "subscriber", "wildcard": false, "condition": "is_below_row_sync_limit" }
              ]
            },
            "comment": null
          }
        ]
      }
    ],
    "conditions": [
      {
        "name": "is_below_collaborator_limit",
        "parameters": [
          { "name": "collaborator_count", "type": "int" },
          { "name": "collaborator_limit", "type": "int" }
        ],
        "expression": "collaborator_count <= collaborator_limit"
      },
      {
        "name": "is_below_row_sync_limit",
        "parameters": [
          { "name": "row_sync_count", "type": "int" },
          { "name": "row_sync_limit", "type": "int" }
        ],
        "expression": "row_sync_count <= row_sync_limit"
      }
    ]
  },
  "canvas_state": {
    "nodes": [
      { "id": "user", "position": { "x": 50, "y": 200 } },
      { "id": "organization", "position": { "x": 250, "y": 200 } },
      { "id": "plan", "position": { "x": 500, "y": 200 } },
      { "id": "feature", "position": { "x": 750, "y": 200 } }
    ],
    "viewport": { "x": 0, "y": 0, "zoom": 1 }
  }
}
