{
  "name": "GitHub RBAC",
  "description": "Repository access control with role hierarchy (user → team → org → repo).",
  "tags": ["rbac", "github", "repository"],
  "model": {
    "schema_version": "1.1",
    "types": [
      { "name": "user", "relations": [] },
      {
        "name": "team",
        "relations": [
          {
            "name": "member",
            "expression": {
              "kind": "direct",
              "grants": [
                { "type": "user", "relation": null, "wildcard": false, "condition": null }
              ]
            },
            "comment": null
          }
        ]
      },
      {
        "name": "organization",
        "relations": [
          {
            "name": "owner",
            "expression": {
              "kind": "direct",
              "grants": [
                { "type": "user", "relation": null, "wildcard": false, "condition": null }
              ]
            },
            "comment": null
          },
          {
            "name": "member",
            "expression": {
              "kind": "union",
              "children": [
                {
                  "kind": "direct",
                  "grants": [
                    { "type": "user", "relation": null, "wildcard": false, "condition": null }
                  ]
                },
                { "kind": "ref", "relation": "owner" }
              ]
            },
            "comment": null
          }
        ]
      },
      {
        "name": "repo",
        "relations": [
          {
            "name": "owner",
            "expression": {
              "kind": "direct",
              "grants": [
                { "type": "organization", "relation": null, "wildcard": false, "condition": null }
              ]
            },
            "comment": null
          },
          {
            "name": "admin",
            "expression": {
              "kind": "union",
              "children": [
                {
                  "kind": "direct",
                  "grants": [
                    { "type": "user", "relation": null, "wildcard": false, "condition": null },
                    { "type": "team", "relation": "member", "wildcard": false, "condition": null }
                  ]
                },
                { "kind": "from", "source_relation": "owner", "parent_relation": "owner" }
              ]
            },
            "comment": null
          },
          {
            "name": "writer",
            "expression": {
              "kind": "union",
              "children": [
                {
                  "kind": "direct",
                  "grants": [
                    { "type": "user", "relation": null, "wildcard": false, "condition": null },
                    { "type": "team", "relation": "member", "wildcard": false, "condition": null }
                  ]
                },
                { "kind": "ref", "relation": "admin" }
              ]
            },
            "comment": null
          },
          {
            "name": "triager",
            "expression": {
              "kind": "union",
              "children": [
                {
                  "kind": "direct",
                  "grants": [
                    { "type": "user", "relation": null, "wildcard": false, "condition": null },
                    { "type": "team", "relation": "member", "wildcard": false, "condition": null }
                  ]
                },
                { "kind": "ref", "relation": "writer" }
              ]
            },
            "comment": null
          },
          {
            "name": "reader",
            "expression": {
              "kind": "union",
              "children": [
                {
                  "kind": "direct",
                  "grants": [
                    { "type": "user", "relation": null, "wildcard": false, "condition": null },
                    { "type": "team", "relation": "member", "wildcard": false, "condition": null }
                  ]
                },
                { "kind": "ref", "relation": "triager" }
              ]
            },
            "comment": null
          }
        ]
      }
    ],
    "conditions": []
  },
  "canvas_state": {
    "nodes": [
      { "id": "user", "position": { "x": 50, "y": 200 } },
      { "id": "team", "position": { "x": 300, "y": 50 } },
      { "id": "organization", "position": { "x": 300, "y": 350 } },
      { "id": "repo", "position": { "x": 600, "y": 200 } }
    ],
    "viewport": { "x": 0, "y": 0, "zoom": 1 }
  }
}
